# GitHub token — needed for the issues/PR pile (and to lift rate limits on code/kep/docs).
# Create a fine-grained or classic token with public-repo read scope.
GITHUB_TOKEN=

# Optional: enforce HMAC verification of incoming GitHub webhooks (leave empty to disable).
GITHUB_WEBHOOK_SECRET=

# Infrastructure (defaults match docker-compose.yml)
QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434
REDIS_URL=redis://localhost:6379

# Anthropic key — only needed later (Streamlit generation). Not required for ingest/index.
ANTHROPIC_API_KEY=
